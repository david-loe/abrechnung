{
  "name": "abrechnung-frontend",
  "version": "2.6.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./*"
  },
  "scripts": {
    "dev": "vite & vue-tsc --noEmit --watch",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint --ext .ts,.js,.vue --ignore-path .gitignore --fix src",
    "i18n:report": "vue-cli-service i18n:report --src \"./src/**/*.?(js|vue)\" --locales \"./src/locales/**/*.json\""
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@vueform/vueform": "^1.13.10",
    "abrechnung-common": "file:../common",
    "axios": "^1.15.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "idb": "^8.0.3",
    "json-editor-vue": "^0.18.1",
    "qrcode": "^1.5.4",
    "qs": "^6.15.1",
    "simple-code-editor": "^2.1.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "vue-select": "^4.0.0-beta.6",
    "vue-to-print": "^1.5.1",
    "vue3-easy-data-table": "^1.5.47"
  },
  "devDependencies": {
    "@types/bootstrap": "^5.2.10",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.0",
    "@types/vue-select": "^3.16.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "es2022": true
    },
    "extends": ["plugin:vue/vue3-essential"],
    "rules": {}
  },
  "browserslist": ["> 1%", "last 2 versions", "not dead"]
}
